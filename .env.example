# Perfil Spring (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Migrations: só no container Flyway (a app não roda Flyway).
# Com spring-boot:run: suba o MySQL (docker compose up -d db), rode migrations
#   docker compose run --rm flyway
#   depois ./mvnw spring-boot:run

# MySQL (usado pelo docker-compose - climb-api conecta ao serviço db)
MYSQL_USER=climb
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootsecret

# Porta no Windows/Mac onde o container MySQL fica exposto (padrão 3307).
# Se nada usar a 3306 no host, pode definir MYSQL_HOST_PORT=3306.
# MYSQL_HOST_PORT=3307

# Datasource
# - docker-compose (serviço climb-api): sobrescrito para jdbc:mysql://db:3306/climb
# - spring-boot:run: o projeto carrega .env via spring-dotenv (ClimbApiApplication),
#   em qualquer SO — execute a partir da raiz do repositório (onde está o .env).
# - IDE: pode usar "Env File" ou as mesmas variáveis; o .env na raiz também é lido ao rodar main.
#
# PowerShell (opcional, só se quiser exportar manualmente para outro comando) — regex correto:
#   [^=]* na chave e \s*=\s* (com ou sem espaço antes do =)
#   Get-Content .env | ForEach-Object {
#     if ($_ -match '^\s*([^#][^=]*)\s*=\s*(.*)$') {
#       Set-Item -Path "Env:$($matches[1].Trim())" -Value $matches[2].Trim().Trim('"')
#     }
#   }
#   .\mvnw.cmd spring-boot:run
# - Banco remoto: defina SPRING_DATASOURCE_URL (e user/senha) no IDE ou no shell.
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/climb?allowPublicKeyRetrieval=true&useSSL=false
# SPRING_DATASOURCE_USERNAME=climb
# SPRING_DATASOURCE_PASSWORD=secret
