# Perfil Spring (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Flyway: definir SPRING_FLYWAY_ENABLED=true no Dokploy/pipeline para rodar migrations em deploy

# MySQL (usado pelo docker-compose - climb-api conecta ao serviço db)
MYSQL_USER=climb
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootsecret

# Datasource - em docker-compose é sobrescrito para jdbc:mysql://db:3306/climb
# Para desenvolvimento local sem compose, descomentar e ajustar:
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/climb
# SPRING_DATASOURCE_USERNAME=climb
# SPRING_DATASOURCE_PASSWORD=secret
